{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "go build ./...",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "go test ./... -v -race -cover",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": { "reveal": "always" }
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "golangci-lint run ./...",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "run sysinfo",
            "type": "shell",
            "command": "go run ./cmd/sysinfo",
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "tidy",
            "type": "shell",
            "command": "go mod tidy",
            "presentation": { "reveal": "silent" }
        }
    ]
}
